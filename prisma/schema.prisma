generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  USER
}

enum FileStatus {
  RECEIVED
  PROCESSING
  PROCESSED
  FAILED
}

enum BatchStatus {
  RECEIVED
  PROCESSING
  COMPLETED
  COMPLETED_WITH_ERRORS
  FAILED
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(USER)
  batches      Batch[]
  files        File[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Batch {
  id           String      @id @default(cuid())
  name         String
  status       BatchStatus @default(RECEIVED)
  totalFiles   Int         @default(0)
  processedFiles Int       @default(0)
  successFiles Int         @default(0)
  errorFiles   Int         @default(0)
  queuedAt     DateTime?
  processingStartedAt DateTime?
  processingFinishedAt DateTime?
  lastError    String?
  uploadedById String
  uploadedBy   User        @relation(fields: [uploadedById], references: [id])
  files        File[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([uploadedById])
}

model File {
  id           String   @id @default(cuid())
  originalName String
  storedName   String
  mimeType     String
  size         Int
  status       FileStatus @default(RECEIVED)
  totalItems   Int      @default(0)
  divergencesCount Int  @default(0)
  analysisData Json?
  analysisError String?
  analyzedAt   DateTime?
  path         String
  batchId      String?
  batch        Batch?   @relation(fields: [batchId], references: [id])
  uploadedById String
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([batchId])
  @@index([uploadedById])
}
